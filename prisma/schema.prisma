generator client {
  provider        = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String
  status      String   @default("online")
  isBot       Boolean  @default(false)
  createdAt   DateTime @default(now())

  messages           Message[]
  reactions          Reaction[]
  channelMembers     ChannelMember[]
  profile            UserProfile?
  missionsCreated    Mission[]
  missionMembers     MissionMember[]
  assignedTasks      MissionTask[]
  inboxItems         InboxItem[]
  assignedQuestions  BlockingQuestion[]
  createdArtifacts   Artifact[]         @relation("ArtifactCreator")
  reviewingArtifacts Artifact[]         @relation("ArtifactReviewer")
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String   @default("")
  skills       String   // JSON array stored as string
  timezone     String   @default("UTC")
  availability String   @default("available")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Mission {
  id          String          @id @default(cuid())
  title       String
  objective   String
  status      String          @default("active")
  channelId   String?
  createdById String
  createdAt   DateTime        @default(now())
  members     MissionMember[]
  tasks       MissionTask[]
  topics      MissionTopic[]
  artifacts   Artifact[]
  questions   BlockingQuestion[]
  inboxItems  InboxItem[]
  createdBy   User            @relation(fields: [createdById], references: [id])
}

model MissionMember {
  missionId String
  userId    String
  role      String   @default("contributor")
  joinedAt  DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@id([missionId, userId])
}

model MissionTask {
  id         String   @id @default(cuid())
  missionId  String
  title      String
  status     String   @default("todo")
  assigneeId String?
  createdAt  DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id])
  assignee   User?    @relation(fields: [assigneeId], references: [id])
}

model Channel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  messages       Message[]
  channelMembers ChannelMember[]
}

model ChannelMember {
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@id([channelId, userId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  userId    String
  channelId String
  threadId  String?
  isAI      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  channel   Channel    @relation(fields: [channelId], references: [id])
  reactions Reaction[]
}

model Reaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model MissionTopic {
  id          String   @id @default(cuid())
  missionId   String
  title       String
  description String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  mission     Mission  @relation(fields: [missionId], references: [id])
  artifacts   Artifact[]
  questions   BlockingQuestion[]
}

model Artifact {
  id          String   @id @default(cuid())
  missionId   String?
  topicId     String?
  channelId   String?
  type        String
  title       String
  content     String
  status      String   @default("draft")
  createdById String
  reviewerId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mission     Mission?      @relation(fields: [missionId], references: [id])
  topic       MissionTopic? @relation(fields: [topicId], references: [id])
  createdBy   User          @relation("ArtifactCreator", fields: [createdById], references: [id])
  reviewer    User?         @relation("ArtifactReviewer", fields: [reviewerId], references: [id])
  inboxItems  InboxItem[]
}

model BlockingQuestion {
  id            String    @id @default(cuid())
  missionId     String?
  topicId       String?
  channelId     String?
  agentUsername  String
  question      String
  context       String?
  answer        String?
  status        String    @default("open")
  assigneeId    String
  createdAt     DateTime  @default(now())
  answeredAt    DateTime?
  mission       Mission?      @relation(fields: [missionId], references: [id])
  topic         MissionTopic? @relation(fields: [topicId], references: [id])
  assignee      User          @relation(fields: [assigneeId], references: [id])
  inboxItems    InboxItem[]
}

model InboxItem {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  priority    String    @default("normal")
  status      String    @default("pending")
  artifactId  String?
  questionId  String?
  missionId   String?
  taskId      String?
  fromAgent   String?
  createdAt   DateTime  @default(now())
  doneAt      DateTime?
  user        User              @relation(fields: [userId], references: [id])
  artifact    Artifact?         @relation(fields: [artifactId], references: [id])
  question    BlockingQuestion? @relation(fields: [questionId], references: [id])
  mission     Mission?          @relation(fields: [missionId], references: [id])
}
